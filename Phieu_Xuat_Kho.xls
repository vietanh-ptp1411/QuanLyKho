
                <html xmlns:o="urn:schemas-microsoft-com:office:office"
                      xmlns:x="urn:schemas-microsoft-com:office:excel"
                      xmlns="http://www.w3.org/TR/REC-html40">
                <head>
                    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
                    <!--[if gte mso 9]>
                    <xml>
                        <x:ExcelWorkbook>
                            <x:ExcelWorksheets>
                                <x:ExcelWorksheet>
                                    <x:Name>Phieu_Xuat_Kho</x:Name>
                                    <x:WorksheetOptions>
                                        <x:DisplayGridlines/>
                                        <x:FitToPage/>
                                        <x:Print>
                                            <x:ValidPrinterInfo/>
                                            <x:PaperSizeIndex>9</x:PaperSizeIndex> <!-- A4 -->
                                            <x:HorizontalResolution>600</x:HorizontalResolution>
                                            <x:VerticalResolution>600</x:VerticalResolution>
                                        </x:Print>
                                    </x:WorksheetOptions>
                                </x:ExcelWorksheet>
                            </x:ExcelWorksheets>
                        </x:ExcelWorkbook>
                    </xml>
                    <![endif]-->
                    <style>
                        body, table { font-family: 'Times New Roman', Times, serif; font-size: 12pt; }
                        table { border-collapse: collapse; width: 100%; }
                        td { padding: 5px; vertical-align: middle; }
                        /* Apply strict borders for cells that have inline border styling */
                        td[style*="border: 1px solid black"] { border: 0.5pt solid windowtext; }
                    </style>
                </head>
                <body>
                    
            <!-- Bảng Master Table chứa toàn bộ nội dung để đảm bảo layout chuẩn khi copy sang Excel -->
            <table>
                <colgroup>
                    <col style="width: 10%;">
                    <col style="width: 23%;">
                    <col style="width: 8%;">
                    <col style="width: 10%;">
                    <col style="width: 20%;">
                    <col style="width: 15%;">
                    <col style="width: 14%;">
                </colgroup>
                <tbody>
                    <!-- Header -->
                    <tr>
                        <td colspan="4" style="font-weight: bold; font-size: 14px;">CÔNG TY CỔ PHẦN TẬP ĐOÀN SÔNG HỒNG THỦ ĐÔ</td>
                        <td colspan="3" style="text-align: right; font-weight: bold; font-size: 14px; vertical-align: top;">
                            SÔNG HỒNG THỦ ĐÔ GROUP
                        </td>
                    </tr>
                    <tr>
                        <td colspan="4">Số 189 Lam Sơn - Vĩnh Yên - Phú Thọ - Việt Nam</td>
                        <td colspan="3" style="text-align: right;"></td>
                    </tr>
                    <tr>
                        <td colspan="4">Tên kho: <span>Kho tổng</span></td>
                        <td colspan="3" style="text-align: right;">21140</td>
                    </tr>
                    <tr>
                        <td colspan="7">Thủ kho: <span>Nguyễn H Nhung</span></td>
                    </tr>
                    <tr>
                        <td colspan="7">Số điện thoại: <span>0983010045</span></td>
                    </tr>
                    <tr><td colspan="7" style="height: 15px;"></td></tr>

                    <!-- Title -->
                    <tr>
                        <td colspan="7" style="text-align: center; font-size: 22px; font-weight: bold;">PHIẾU XUẤT KHO KINH DOANH SHTĐ</td>
                    </tr>
                    <tr>
                        <td colspan="7" style="text-align: center; font-size: 14px;">Số phiếu xuất: <span>21140</span></td>
                    </tr>
                    <tr><td colspan="7" style="height: 15px;"></td></tr>

                    <!-- Info -->
                    <tr>
                        <td colspan="2" style="font-weight: bold;">Họ và tên người xin cấp vật tư:</td>
                        <td colspan="5">Trần Thị Mỹ Linh</td>
                    </tr>
                    <tr>
                        <td colspan="2" style="font-weight: bold;">Bộ Phận:</td>
                        <td colspan="5">café ăn sáng dv2</td>
                    </tr>
                    <tr>
                        <td colspan="2" style="font-weight: bold;">Nơi nhận:</td>
                        <td colspan="2">dịch vụ 2</td>
                        <td colspan="3" style="text-align: right; font-weight: bold;">
                            Ngày tháng xuất kho: <span style="font-weight: normal;">27-03-26</span>
                        </td>
                    </tr>
                    <tr><td colspan="7" style="height: 10px;"></td></tr>

                    <!-- Data Table Header -->
                    <tr style="background-color: #d1d5db; font-weight: bold; text-align: center;">
                        <td style="border: 1px solid black; padding: 8px;">Số phiếu<br>xuất</td>
                        <td style="border: 1px solid black; padding: 8px;">Tên mặt hàng</td>
                        <td style="border: 1px solid black; padding: 8px;">Đvt</td>
                        <td style="border: 1px solid black; padding: 8px;">Số<br>lượng</td>
                        <td style="border: 1px solid black; padding: 8px;">Mục đích sử dụng</td>
                        <td style="border: 1px solid black; padding: 8px;">Nơi nhận</td>
                        <td style="border: 1px solid black; padding: 8px;">Mã vật tư</td>
                    </tr>

                    <!-- Data Row -->
                    <tr style="text-align: center;">
                        <td style="border: 1px solid black; padding: 8px;">21140</td>
                        <td style="border: 1px solid black; padding: 8px; text-align: left;">lọ tăm sứ</td>
                        <td style="border: 1px solid black; padding: 8px;">chiếc</td>
                        <td style="border: 1px solid black; padding: 8px; text-align: right;">15.0</td>
                        <td style="border: 1px solid black; padding: 8px; text-align: left;">phục vụ công việc</td>
                        <td style="border: 1px solid black; padding: 8px;">dịch vụ 2</td>
                        <td style="border: 1px solid black; padding: 8px;">lot</td>
                    </tr>

                    <!-- Trống dự phòng (Người dùng có thể thêm dòng sau khi tải Excel) -->
                    <tr style="text-align: center; height: 28px;">
                        <td style="border: 1px solid black; padding: 8px;"></td>
                        <td style="border: 1px solid black; padding: 8px; text-align: left;"></td>
                        <td style="border: 1px solid black; padding: 8px;"></td>
                        <td style="border: 1px solid black; padding: 8px; text-align: right;"></td>
                        <td style="border: 1px solid black; padding: 8px; text-align: left;"></td>
                        <td style="border: 1px solid black; padding: 8px;"></td>
                        <td style="border: 1px solid black; padding: 8px;"></td>
                    </tr>

                    <!-- Total Row -->
                    <tr style="text-align: center;">
                        <td colspan="3" style="border: 1px solid black; padding: 8px; font-weight: bold;">Tổng cộng</td>
                        <td style="border: 1px solid black; padding: 8px; font-weight: bold; text-align: right;">15.0</td>
                        <td style="border: 1px solid black; padding: 8px;"></td>
                        <td style="border: 1px solid black; padding: 8px;"></td>
                        <td style="border: 1px solid black; padding: 8px;"></td>
                    </tr>
                    <tr><td colspan="7" style="height: 25px;"></td></tr>

                    <!-- Signatures -->
                    <tr style="text-align: center; font-weight: bold;">
                        <td colspan="2">Thủ kho</td>
                        <td colspan="2">Người nhận hàng</td>
                        <td colspan="2">Kế toán</td>
                        <td colspan="1">Giám đốc</td>
                    </tr>
                    <tr style="text-align: center; font-style: italic;">
                        <td colspan="2">(Ký, họ tên)</td>
                        <td colspan="2">(Ký, họ tên)</td>
                        <td colspan="2">(Ký, họ tên)</td>
                        <td colspan="1">(Ký, họ tên)</td>
                    </tr>
                    <tr><td colspan="7" style="height: 70px;"></td></tr>
                    <tr style="text-align: center;">
                        <td colspan="2"></td>
                        <td colspan="2" style="font-weight: bold; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">Linh</td>
                        <td colspan="2"></td>
                        <td colspan="1"></td>
                    </tr>
                </tbody>
            </table>
        
                </body>
                </html>
            