<Window x:Class="QuanLyKho.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quản Lý Kho - Sông Hồng Thủ Đô"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════ SIDEBAR ════════ -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <!-- Brand Header -->
                <StackPanel DockPanel.Dock="Top" Margin="24,32,24,8">
                    <Border Width="52" Height="52" CornerRadius="14"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563EB" Offset="0"/>
                                <GradientStop Color="#3B82F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <materialDesign:PackIcon Kind="Warehouse" Width="28" Height="28"
                                                 Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Q U Ả N   L Ý   K H O" FontSize="14" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,2"/>
                    <TextBlock Text="Sông Hồng Thủ Đô" FontSize="11"
                               Foreground="#64748B" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Divider -->
                <Border DockPanel.Dock="Top" Height="1" Background="#1E293B" Margin="24,12,24,8">
                    <Border Background="#334155" Opacity="0.5"/>
                </Border>

                <!-- Navigation Menu -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding MenuItems}"
                             SelectedItem="{Binding SelectedMenuItem}"
                             Background="Transparent" BorderThickness="0"
                             Margin="12,4,12,12">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="10" Padding="14,10">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                <GradientStop Color="#2563EB" Offset="0"/>
                                                                <GradientStop Color="#3B82F6" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding Icon}"
                                                             Width="20" Height="20"
                                                             Foreground="#94A3B8"
                                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#CBD5E1" FontSize="13"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ════════ CONTENT AREA ════════ -->
        <Border Grid.Column="1" Background="#F1F5F9">
            <ContentControl Content="{Binding CurrentView}" Margin="32,24,32,24"/>
        </Border>
    </Grid>
</Window>
