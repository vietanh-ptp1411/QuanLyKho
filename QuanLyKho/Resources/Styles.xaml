<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Nút chính: nền đỏ, chữ trắng, to rõ -->
    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="#C62828"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
    </Style>

    <!-- Nút phụ: nền xanh -->
    <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="#1565C0"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
    </Style>

    <!-- Nút xanh lá (Lưu) -->
    <Style x:Key="BtnSave" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="#2E7D32"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,8"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
    </Style>

    <!-- Nút xóa: đỏ viền -->
    <Style x:Key="BtnDelete" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="BorderBrush" Value="#C62828"/>
        <Setter Property="Foreground" Value="#C62828"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
    </Style>

    <!-- Nút hủy: xám -->
    <Style x:Key="BtnCancel" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
    </Style>

    <!-- Tiêu đề trang -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- Compact TextBox for filter bars -->
    <Style x:Key="FilterTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.8"/>
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style x:Key="FilterComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.8"/>
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style x:Key="FilterDatePicker" TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.8"/>
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Form field TextBox -->
    <Style x:Key="FormTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,8"/>
    </Style>

    <Style x:Key="FormComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,8"/>
    </Style>

    <Style x:Key="FormDatePicker" TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

</ResourceDictionary>
