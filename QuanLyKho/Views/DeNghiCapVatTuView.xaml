<UserControl x:Class="QuanLyKho.Views.DeNghiCapVatTuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:QuanLyKho.Helpers">
    <Grid>
        <!-- List View -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="ĐỀ NGHỊ CẤP VẬT TƯ" Style="{StaticResource PageTitleRed}"/>

            <Button Grid.Row="1" Command="{Binding AddNewCommand}" Style="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Left" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Tạo đề nghị"/>
                </StackPanel>
            </Button>

            <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedPhieu}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT" Width="55"
                                        Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                        Converter={StaticResource IndexConverter}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Số phiếu" Binding="{Binding SoPhieu}" Width="180"/>
                    <DataGridTextColumn Header="Ngày" Binding="{Binding NgayDeNghi, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Người đề nghị" Binding="{Binding NguoiDeNghi}" Width="180"/>
                    <DataGridTextColumn Header="Bộ phận" Binding="{Binding BoPhan.TenBoPhan}" Width="150"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai, Converter={StaticResource TrangThaiFormat}}" Width="120"/>
                    <DataGridTemplateColumn Header="Thao tác" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Command="{Binding DataContext.EditPhieuItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource BtnGridEdit}" Margin="0,0,4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sửa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeletePhieuItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource BtnGridDelete}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Xóa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Phân trang -->
            <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1"
                    CornerRadius="0,0,8,8" Padding="12,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Foreground="#64748B">
                        <Run Text="Hiển thị "/>
                        <Run Text="{Binding DanhSach.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" mục"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding FirstPageCommand}" Content="⟨⟨" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <Button Command="{Binding PrevPageCommand}" Content="⟨" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0">
                            <Run Text="Trang "/>
                            <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                        <Button Command="{Binding NextPageCommand}" Content="⟩" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <Button Command="{Binding LastPageCommand}" Content="⟩⟩" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Edit Form - Paper Style -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <DockPanel Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="Số phiếu:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding EditSoPhieu}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,15,0"/>

                        <TextBlock Text="Ngày:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker SelectedDate="{Binding EditNgayDeNghi}" Width="130" Margin="0,0,15,0"
                                    Style="{StaticResource FormDatePicker}"/>

                        <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox SelectedIndex="{Binding EditTrangThai}" Width="120" Margin="0,0,10,0"
                                  Style="{StaticResource FormComboBox}">
                            <ComboBoxItem Content="Nháp"/>
                            <ComboBoxItem Content="Đã duyệt"/>
                            <ComboBoxItem Content="Đã cấp"/>
                            <ComboBoxItem Content="Từ chối"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Lưu"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Quay lại" Command="{Binding CancelEditCommand}" Style="{StaticResource BtnCancel}"/>
                    </StackPanel>
                </DockPanel>

                <!-- Paper Form -->
                <Border Grid.Row="1" Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                        Padding="40,30" MaxWidth="900" HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Header -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left - Company -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="CÔNG TY CP TẬP ĐOÀN" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="SÔNG HỒNG THỦ ĐÔ" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Right - National -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Độc lập - Tự do - Hạnh phúc" FontSize="11"
                                           HorizontalAlignment="Center" TextDecorations="Underline"/>
                            </StackPanel>
                        </Grid>

                        <!-- Date line -->
                        <TextBlock HorizontalAlignment="Right" FontStyle="Italic" FontSize="11" Margin="0,5,40,15">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="......, ngày {0:dd} tháng {0:MM} năm {0:yyyy}">
                                    <Binding Path="EditNgayDeNghi"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- Title -->
                        <TextBlock Text="GIẤY ĐỀ NGHỊ CẤP VẬT TƯ" FontWeight="Bold" FontSize="20"
                                   HorizontalAlignment="Center" Margin="0,10,0,20"/>

                        <!-- Info Section -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Họ tên: " FontSize="13" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding EditNguoiDeNghi, UpdateSourceTrigger=PropertyChanged}"
                                         Width="200" FontSize="13" BorderThickness="0,0,0,1" BorderBrush="#999"
                                         Padding="5,3" Background="Transparent"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Chức vụ: " FontSize="13" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding EditChucVu, UpdateSourceTrigger=PropertyChanged}"
                                         Width="200" FontSize="13" BorderThickness="0,0,0,1" BorderBrush="#999"
                                         Padding="5,3" Background="Transparent"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Bộ phận: " FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding BoPhans}" SelectedItem="{Binding EditBoPhan}"
                                          DisplayMemberPath="TenBoPhan" Width="200" FontSize="13"
                                          BorderThickness="0,0,0,1" BorderBrush="#999" Background="Transparent"
                                          materialDesign:HintAssist.Hint="Chọn bộ phận"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Số điện thoại: " FontSize="13" VerticalAlignment="Center"/>
                                <TextBox Width="180" FontSize="13" BorderThickness="0,0,0,1" BorderBrush="#999"
                                         Padding="5,3" Background="Transparent"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Xin cấp các loại vật tư sau:" FontSize="13" Margin="0,0,0,10"/>

                        <!-- Data Table -->
                        <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,0,5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Table Header -->
                                <Grid Background="#F3F4F6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="STT" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="Tên vật tư (Quy cách, mẫu&#x0a;mã, thông số kỹ thuật...)"
                                                   FontWeight="Bold" FontSize="11" TextWrapping="Wrap"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="ĐVT" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="3" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                        <TextBlock Text="SL&#x0a;tồn&#x0a;kho" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="4" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                        <TextBlock Text="SL&#x0a;đề&#x0a;nghị" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="5" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                        <TextBlock Text="SL&#x0a;được&#x0a;duyệt" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="6" BorderBrush="Black" BorderThickness="0,0,0,1" Padding="5">
                                        <TextBlock Text="Ghi&#x0a;chú" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- Table Data -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding ChiTietRows}" AlternationCount="1000">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                                    <TextBlock Text="{Binding Path=(ItemsControl.AlternationIndex),
                                                               RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                               Converter={StaticResource IndexConverter}}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                                </Border>
                                                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                    <ComboBox ItemsSource="{Binding DataContext.VatTus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              SelectedItem="{Binding VatTu, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="TenVatTu" IsEditable="True" FontSize="12"
                                                              helpers:AutoCompleteBehavior.IsEnabled="True"
                                                              BorderThickness="0" Background="Transparent"
                                                              materialDesign:HintAssist.Hint="Gõ để tìm vật tư"/>
                                                </Border>
                                                <Border Grid.Column="2" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                                    <TextBlock Text="{Binding VatTu.DonViTinh.TenDonVi}" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="3" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                    <TextBox Text="" BorderThickness="0" FontSize="12" TextAlignment="Center"
                                                             Background="Transparent" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="4" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                    <TextBox Text="{Binding SoLuongYeuCau, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" FontSize="12" TextAlignment="Center"
                                                             Background="Transparent" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="5" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                    <TextBox Text="{Binding SoLuongDaCap, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" FontSize="12" TextAlignment="Center"
                                                             Background="Transparent" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="6" BorderBrush="Black" BorderThickness="0,0,0,1" Padding="2">
                                                    <Grid>
                                                        <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}"
                                                                 BorderThickness="0" FontSize="11" Background="Transparent"
                                                                 VerticalAlignment="Center"/>
                                                        <Button Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                Width="18" Height="18" Padding="0" Margin="0,0,2,0"
                                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                                Foreground="#DC2626" ToolTip="Xóa dòng">
                                                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <!-- Add Row Button -->
                        <Button Command="{Binding AddRowCommand}" HorizontalAlignment="Left"
                                Margin="0,5,0,15" Padding="10,5"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text=" Thêm dòng" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <!-- Footer Summary -->
                        <TextBlock FontStyle="Italic" FontSize="12" Margin="0,0,0,20">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="(Tổng: {0:D2} loại. Để sử dụng: {1})">
                                    <Binding Path="ChiTietRows.Count"/>
                                    <Binding Path="EditGhiChu"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- Ghi chú input -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="Mục đích sử dụng: " FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding EditGhiChu, UpdateSourceTrigger=PropertyChanged}"
                                     Width="300" FontSize="12" BorderThickness="0,0,0,1" BorderBrush="#999"
                                     Padding="5,3" Background="Transparent"/>
                        </StackPanel>

                        <!-- Signature Section -->
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Người duyệt" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock Text="" Height="60"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Phòng TC-HC" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock Text="" Height="60"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="CB phụ trách" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock Text="" Height="60"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="Người đề nghị" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock Text="" Height="60"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
