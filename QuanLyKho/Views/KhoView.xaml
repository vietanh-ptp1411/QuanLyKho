<UserControl x:Class="QuanLyKho.Views.KhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="Quản lý kho" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding AddCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Thêm kho"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding EditCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Pencil" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Sửa"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" Style="{StaticResource BtnDelete}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xóa"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <materialDesign:Card Grid.Row="1" Padding="16" Margin="0,0,0,8"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <WrapPanel>
                    <StackPanel Margin="0,0,15,8">
                        <TextBlock Text="Mã kho" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditMaKho, UpdateSourceTrigger=PropertyChanged}" Width="150"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,8">
                        <TextBlock Text="Tên kho" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditTenKho, UpdateSourceTrigger=PropertyChanged}" Width="250"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Địa chỉ" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditDiaChi, UpdateSourceTrigger=PropertyChanged}" Width="350"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Lưu"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Hủy" Command="{Binding CancelCommand}" Style="{StaticResource BtnCancel}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                  Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã kho" Binding="{Binding MaKho}" Width="120"/>
                <DataGridTextColumn Header="Tên kho" Binding="{Binding TenKho}" Width="250"/>
                <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
