<UserControl x:Class="QuanLyKho.Views.KhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề màu đỏ căn giữa -->
        <TextBlock Text="QUẢN LÝ KHO" Style="{StaticResource PageTitleRed}"/>

        <!-- Nút thêm mới bên trái -->
        <Button Grid.Row="1" Command="{Binding AddCommand}" Style="{StaticResource BtnAddGreen}"
                HorizontalAlignment="Left" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Thêm kho"/>
            </StackPanel>
        </Button>

        <!-- Form chỉnh sửa -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,15"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <WrapPanel>
                    <StackPanel Margin="0,0,15,8">
                        <TextBlock Text="Mã kho" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditMaKho, UpdateSourceTrigger=PropertyChanged}" Width="150"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,8">
                        <TextBlock Text="Tên kho" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditTenKho, UpdateSourceTrigger=PropertyChanged}" Width="250"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Địa chỉ" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditDiaChi, UpdateSourceTrigger=PropertyChanged}" Width="350"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Lưu"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Hủy" Command="{Binding CancelCommand}" Style="{StaticResource BtnCancel}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- DataGrid giữ nguyên -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                  Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã kho" Binding="{Binding MaKho}" Width="120"/>
                <DataGridTextColumn Header="Tên kho" Binding="{Binding TenKho}" Width="250"/>
                <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
