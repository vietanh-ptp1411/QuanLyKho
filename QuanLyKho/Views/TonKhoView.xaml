<UserControl x:Class="QuanLyKho.Views.TonKhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Tồn kho" Style="{StaticResource PageTitle}"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                     Width="260" materialDesign:HintAssist.Hint="Tìm mã hoặc tên vật tư..."
                     Style="{StaticResource FilterTextBox}"
                     Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding Khos}" SelectedItem="{Binding FilterKho}"
                      DisplayMemberPath="TenKho" Width="180" Margin="0,0,8,0"
                      materialDesign:HintAssist.Hint="Lọc theo kho"
                      Style="{StaticResource FilterComboBox}"
                      materialDesign:TextFieldAssist.HasClearButton="True"/>
            <ComboBox ItemsSource="{Binding NhomVatTus}" SelectedItem="{Binding FilterNhom}"
                      DisplayMemberPath="TenNhom" Width="180"
                      materialDesign:HintAssist.Hint="Lọc nhóm VT"
                      Style="{StaticResource FilterComboBox}"
                      materialDesign:TextFieldAssist.HasClearButton="True"/>
        </WrapPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã VT" Binding="{Binding MaVatTu}" Width="90"/>
                <DataGridTextColumn Header="Tên vật tư" Binding="{Binding TenVatTu}" Width="*"/>
                <DataGridTextColumn Header="ĐVT" Binding="{Binding DonViTinh}" Width="70"/>
                <DataGridTextColumn Header="Nhóm" Binding="{Binding NhomVatTu}" Width="110"/>
                <DataGridTextColumn Header="Kho" Binding="{Binding TenKho}" Width="120"/>
                <DataGridTextColumn Header="SL Nhập" Binding="{Binding SoLuongNhap, StringFormat=N2}" Width="95">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="SL Xuất" Binding="{Binding SoLuongXuat, StringFormat=N2}" Width="95">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Tồn cuối" Binding="{Binding TonCuoi, StringFormat=N2}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
