<UserControl x:Class="QuanLyKho.Views.VatTuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Vật tư" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding AddCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Thêm vật tư"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding EditCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Pencil" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Sửa"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" Style="{StaticResource BtnDelete}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xóa"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Search bar -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                     Width="280" materialDesign:HintAssist.Hint="Tìm theo mã hoặc tên vật tư..."
                     Style="{StaticResource FilterTextBox}"
                     Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding NhomVatTus}" SelectedItem="{Binding FilterNhom}"
                      DisplayMemberPath="TenNhom" Width="200"
                      materialDesign:HintAssist.Hint="Lọc nhóm VT"
                      Style="{StaticResource FilterComboBox}"
                      materialDesign:TextFieldAssist.HasClearButton="True"/>
        </WrapPanel>

        <!-- Edit Form -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,8"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <WrapPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Mã vật tư *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditMaVatTu, UpdateSourceTrigger=PropertyChanged}" Width="150"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Tên vật tư *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditTenVatTu, UpdateSourceTrigger=PropertyChanged}" Width="300"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Nhóm vật tư" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding NhomVatTus}" SelectedItem="{Binding EditNhomVatTu}"
                                  DisplayMemberPath="TenNhom" Width="180"
                                  Style="{StaticResource FormComboBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Đơn vị tính" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding DonViTinhs}" SelectedItem="{Binding EditDonViTinh}"
                                  DisplayMemberPath="TenDonVi" Width="140"
                                  Style="{StaticResource FormComboBox}"/>
                    </StackPanel>
                </WrapPanel>
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Ghi chú" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditGhiChu, UpdateSourceTrigger=PropertyChanged}" Width="500" HorizontalAlignment="Left"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Lưu"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Hủy" Command="{Binding CancelCommand}" Style="{StaticResource BtnCancel}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã VT" Binding="{Binding MaVatTu}" Width="100"/>
                <DataGridTextColumn Header="Tên vật tư" Binding="{Binding TenVatTu}" Width="*"/>
                <DataGridTextColumn Header="Nhóm" Binding="{Binding NhomVatTu.TenNhom}" Width="150"/>
                <DataGridTextColumn Header="ĐVT" Binding="{Binding DonViTinh.TenDonVi}" Width="90"/>
                <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
