<UserControl x:Class="QuanLyKho.Views.VatTuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Text="QUẢN LÝ VẬT TƯ" Style="{StaticResource PageTitleRed}"/>

        <!-- Nút thêm mới -->
        <Button Grid.Row="1" Command="{Binding AddCommand}" Style="{StaticResource BtnAddGreen}"
                HorizontalAlignment="Left" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Thêm vật tư"/>
            </StackPanel>
        </Button>

        <!-- Form chỉnh sửa inline -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,12"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Sửa vật tư"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNew}" Value="True">
                                    <Setter Property="Text" Value="Thêm vật tư mới"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <WrapPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Mã vật tư" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditMaVatTu, UpdateSourceTrigger=PropertyChanged}"
                                 Width="150" Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Tên vật tư" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditTenVatTu, UpdateSourceTrigger=PropertyChanged}"
                                 Width="250" Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Nhóm vật tư" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding NhomVatTus}" SelectedItem="{Binding EditNhomVatTu}"
                                  DisplayMemberPath="TenNhom" Width="200"
                                  Style="{StaticResource FormComboBox}"
                                  materialDesign:HintAssist.Hint="Chọn nhóm vật tư"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="Đơn vị tính" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding DonViTinhs}" SelectedItem="{Binding EditDonViTinh}"
                                  DisplayMemberPath="TenDonVi" Width="160"
                                  Style="{StaticResource FormComboBox}"
                                  materialDesign:HintAssist.Hint="Chọn ĐVT"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Ghi chú" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditGhiChu, UpdateSourceTrigger=PropertyChanged}"
                                 Width="250" Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Lưu"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Hủy" Command="{Binding CancelCommand}" Style="{StaticResource BtnCancel}"/>
                </StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12"
                           Margin="0,8,0,0" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Search bar -->
        <WrapPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                     Width="280" materialDesign:HintAssist.Hint="Tìm theo mã hoặc tên vật tư..."
                     Style="{StaticResource FilterTextBox}"
                     Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding NhomVatTus}" SelectedItem="{Binding FilterNhom}"
                      DisplayMemberPath="TenNhom" Width="200"
                      materialDesign:HintAssist.Hint="Lọc nhóm VT"
                      Style="{StaticResource FilterComboBox}"
                      materialDesign:TextFieldAssist.HasClearButton="True"/>
        </WrapPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="4" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Width="55"
                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                    Converter={StaticResource IndexConverter}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Mã VT" Binding="{Binding MaVatTu}" Width="120"/>
                <DataGridTextColumn Header="Tên vật tư" Binding="{Binding TenVatTu}" Width="*"/>
                <DataGridTextColumn Header="Nhóm vật tư" Binding="{Binding NhomVatTu.TenNhom}" Width="180"/>
                <DataGridTextColumn Header="ĐVT" Binding="{Binding DonViTinh.TenDonVi}" Width="100"/>
                <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="200"/>
                <DataGridTemplateColumn Header="Thao tác" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource BtnGridEdit}" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Sửa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource BtnGridDelete}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Xóa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Phân trang -->
        <Border Grid.Row="5" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1"
                CornerRadius="0,0,8,8" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Foreground="#64748B">
                    <Run Text="Hiển thị "/>
                    <Run Text="{Binding DanhSach.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text=" mục"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding FirstPageCommand}" Content="⟨⟨" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    <Button Command="{Binding PrevPageCommand}" Content="⟨" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,8,0"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0">
                        <Run Text="Trang "/>
                        <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <Button Command="{Binding NextPageCommand}" Content="⟩" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    <Button Command="{Binding LastPageCommand}" Content="⟩⟩" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
