<UserControl x:Class="QuanLyKho.Views.XuatKhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:QuanLyKho.Helpers">
    <Grid>
        <!-- List View -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="XUẤT KHO" Style="{StaticResource PageTitleRed}"/>

            <!-- Filters + Tạo phiếu -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                <Button Command="{Binding AddNewCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Tạo phiếu xuất"/>
                    </StackPanel>
                </Button>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                         Width="220" materialDesign:HintAssist.Hint="Tìm số phiếu, người nhận..."
                         Style="{StaticResource FilterTextBox}"
                         Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FilterFromDate}" Width="145" Margin="0,0,6,0"
                            materialDesign:HintAssist.Hint="Từ ngày" Style="{StaticResource FilterDatePicker}"/>
                <DatePicker SelectedDate="{Binding FilterToDate}" Width="145" Margin="0,0,6,0"
                            materialDesign:HintAssist.Hint="Đến ngày" Style="{StaticResource FilterDatePicker}"/>
                <Button Command="{Binding FilterCommand}" Style="{StaticResource BtnSecondary}" Height="38">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Filter" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Lọc"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedPhieu}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="All" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="Bold"/>
                                    <CheckBox IsChecked="{Binding DataContext.IsAllSelected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="STT" Width="55"
                                        Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                        Converter={StaticResource IndexConverter}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Số phiếu" Binding="{Binding SoPhieu}" Width="180"/>
                    <DataGridTextColumn Header="Ngày xuất" Binding="{Binding NgayXuat, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Người nhận" Binding="{Binding NguoiNhan}" Width="*"/>
                    <DataGridTextColumn Header="Kho" Binding="{Binding Kho.TenKho}" Width="130"/>
                    <DataGridTextColumn Header="Bộ phận" Binding="{Binding BoPhan.TenBoPhan}" Width="130"/>
                    <DataGridTemplateColumn Header="Thao tác" Width="165">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel VerticalAlignment="Center" LastChildFill="False" Margin="8,0">
                                    <Button DockPanel.Dock="Left" Command="{Binding DataContext.EditPhieuItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource BtnGridEdit}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sửa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button DockPanel.Dock="Right" Command="{Binding DataContext.DeletePhieuItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource BtnGridDelete}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Xóa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Phân trang -->
            <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1"
                    CornerRadius="0,0,8,8" Padding="12,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Foreground="#64748B">
                        <Run Text="Hiển thị "/>
                        <Run Text="{Binding DanhSach.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" mục"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding FirstPageCommand}" Content="⟨⟨" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <Button Command="{Binding PrevPageCommand}" Content="⟨" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0">
                            <Run Text="Trang "/>
                            <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                        <Button Command="{Binding NextPageCommand}" Content="⟩" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <Button Command="{Binding LastPageCommand}" Content="⟩⟩" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Nút hành động -->
            <WrapPanel Grid.Row="4" Margin="0,10,0,0">
                <Button Command="{Binding PrintCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Printer" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="In"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xuất PDF"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportExcelCommand}" Style="{StaticResource BtnExcel}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xuất Excel"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Grid>

        <!-- Edit Form - Paper Style -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <DockPanel Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="Số phiếu:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding EditSoPhieu}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,15,0"/>

                        <TextBlock Text="Ngày:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker SelectedDate="{Binding EditNgayXuat}" Width="130" Margin="0,0,15,0"
                                    Style="{StaticResource FormDatePicker}"/>

                        <TextBlock Text="Kho xuất *:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding Khos}" SelectedItem="{Binding EditKho}"
                                  DisplayMemberPath="TenKho" Width="160" Margin="0,0,15,0"
                                  Style="{StaticResource FormComboBox}"/>

                        <TextBlock Text="Bộ phận:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding BoPhans}" SelectedItem="{Binding EditBoPhan}"
                                  DisplayMemberPath="TenBoPhan" Width="150" Margin="0,0,10,0"
                                  Style="{StaticResource FormComboBox}"
                                  materialDesign:TextFieldAssist.HasClearButton="True"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Lưu phiếu"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Quay lại" Command="{Binding CancelEditCommand}" Style="{StaticResource BtnCancel}"/>
                    </StackPanel>
                </DockPanel>

                <!-- Paper Form -->
                <Border Grid.Row="1" Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                        Padding="40,30" MaxWidth="950" HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Header -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left - Company -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CÔNG TY CỔ PHẦN TẬP ĐOÀN SÔNG HỒNG THỦ ĐÔ"
                                           FontWeight="Bold" FontSize="11"/>
                                <TextBlock Text="Khu đô thị Bắc Đầm Vạc" FontStyle="Italic" FontSize="10"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Kho: " FontSize="10"/>
                                    <TextBlock Text="{Binding EditKho.TenKho}" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="SÔNG HỒNG THỦ ĐÔ" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>

                        <!-- Title -->
                        <TextBlock Text="PHIẾU XUẤT KHO KINH DOANH SHTD" FontWeight="Bold" FontSize="17"
                                   HorizontalAlignment="Center" Margin="0,10,0,5"/>

                        <!-- Số phiếu -->
                        <TextBlock HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,15">
                            <Run Text="Số phiếu xuất: "/>
                            <Run Text="{Binding EditSoPhieu, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- Info Section - 2 columns -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Họ tên người xin cấp vật tư : " FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EditNguoiNhan, UpdateSourceTrigger=PropertyChanged}"
                                             Width="200" FontSize="13" BorderThickness="0,0,0,1" BorderBrush="#999"
                                             Padding="5,3" Background="Transparent"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Bộ Phận: " FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding EditBoPhan.TenBoPhan}" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Nơi nhận: " FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EditNoiNhan, UpdateSourceTrigger=PropertyChanged}"
                                             Width="250" FontSize="13" BorderThickness="0,0,0,1" BorderBrush="#999"
                                             Padding="5,3" Background="Transparent"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Ngày tháng xuất: " FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="13" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <Binding Path="EditNgayXuat" StringFormat="dd/MM/yyyy"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Mục đích sử dụng: " FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding EditMucDichSuDung, UpdateSourceTrigger=PropertyChanged}"
                                             Width="200" FontSize="13" BorderThickness="0,0,0,1" BorderBrush="#999"
                                             Padding="5,3" Background="Transparent"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Data Table -->
                        <Border BorderBrush="Black" BorderThickness="1" Margin="0,10,0,5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Table Header -->
                                <Grid Background="#E0E0E0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="45"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="STT" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="Tên mặt hàng" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="Đvt" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="3" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                        <TextBlock Text="Số&#x0a;lượng" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="4" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="Mục đích&#x0a;sử dụng" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="5" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="Nơi nhận" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="6" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="5">
                                        <TextBlock Text="Mã vật tư" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="7" BorderBrush="Black" BorderThickness="0,0,0,1" Padding="3">
                                        <TextBlock Text="Xóa" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- Table Data -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding ChiTietRows}" AlternationCount="1000">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="45"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                                    <TextBlock Text="{Binding Path=(ItemsControl.AlternationIndex),
                                                               RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                               Converter={StaticResource IndexConverter}}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                                </Border>
                                                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                    <ComboBox ItemsSource="{Binding DataContext.VatTus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              SelectedItem="{Binding VatTu, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="TenVatTu" IsEditable="True" FontSize="12"
                                                              helpers:AutoCompleteBehavior.IsEnabled="True"
                                                              BorderThickness="0" Background="Transparent"
                                                              materialDesign:HintAssist.Hint="Gõ để tìm vật tư"/>
                                                </Border>
                                                <Border Grid.Column="2" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                                    <TextBlock Text="{Binding VatTu.DonViTinh.TenDonVi}" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="3" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="2">
                                                    <TextBox Text="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" FontSize="12" TextAlignment="Center"
                                                             Background="Transparent" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="4" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                                    <TextBlock Text="{Binding DataContext.EditMucDichSuDung, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Column="5" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                                    <TextBlock Text="{Binding DataContext.EditNoiNhan, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Column="6" BorderBrush="Black" BorderThickness="0,0,1,1" Padding="3">
                                                    <TextBlock Text="{Binding VatTu.MaVatTu}" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="7" BorderBrush="Black" BorderThickness="0,0,0,1">
                                                    <Button Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            Width="28" Height="28" Padding="0"
                                                            Style="{StaticResource MaterialDesignFlatButton}"
                                                            Foreground="#DC2626" ToolTip="Xóa dòng">
                                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                    </Button>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <!-- Tổng cộng row -->
                        <Border BorderBrush="Black" BorderThickness="1,0,1,1" Margin="0,0,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="365"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Tổng cộng:" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="1" Text="{Binding TongSoLuong, StringFormat=N2, Mode=OneWay}"
                                           FontWeight="Bold" FontSize="12" Foreground="#DC2626"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5"/>
                                <Border Grid.Column="2" Padding="5"/>
                            </Grid>
                        </Border>

                        <!-- Add Row Button -->
                        <Button Command="{Binding AddRowCommand}" HorizontalAlignment="Left"
                                Margin="0,5,0,15" Padding="10,5"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text=" Thêm dòng" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <!-- Signature Section -->
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Thủ kho" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock Text="(ký ,họ tên)" FontStyle="Italic" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding EditThuKho, UpdateSourceTrigger=PropertyChanged}"
                                         Width="100" FontSize="10" BorderThickness="0" Background="Transparent"
                                         TextAlignment="Center" Margin="0,30,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Người nhận hàng" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock Text="(ký ,họ tên)" FontStyle="Italic" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock Text="" Height="60"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Kế toán" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock Text="(ký ,họ tên)" FontStyle="Italic" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding EditKeToanTruong, UpdateSourceTrigger=PropertyChanged}"
                                         Width="100" FontSize="10" BorderThickness="0" Background="Transparent"
                                         TextAlignment="Center" Margin="0,30,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="Giám đốc" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock Text="(ký ,họ tên)" FontStyle="Italic" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding EditGiamDoc, UpdateSourceTrigger=PropertyChanged}"
                                         Width="100" FontSize="10" BorderThickness="0" Background="Transparent"
                                         TextAlignment="Center" Margin="0,30,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
