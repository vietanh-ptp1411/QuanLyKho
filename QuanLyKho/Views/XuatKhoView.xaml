<UserControl x:Class="QuanLyKho.Views.XuatKhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <!-- List View -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="Xuất kho" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding AddNewCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Tạo phiếu xuất"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditPhieuCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Eye" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Xem / Sửa"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeletePhieuCommand}" Style="{StaticResource BtnDelete}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Xóa"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>

            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                         Width="220" materialDesign:HintAssist.Hint="Tìm số phiếu, người nhận..."
                         Style="{StaticResource FilterTextBox}"
                         Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FilterFromDate}" Width="145" Margin="0,0,6,0"
                            materialDesign:HintAssist.Hint="Từ ngày" Style="{StaticResource FilterDatePicker}"/>
                <DatePicker SelectedDate="{Binding FilterToDate}" Width="145" Margin="0,0,6,0"
                            materialDesign:HintAssist.Hint="Đến ngày" Style="{StaticResource FilterDatePicker}"/>
                <Button Command="{Binding FilterCommand}" Style="{StaticResource BtnSecondary}" Height="38">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Filter" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Lọc"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedPhieu}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Số phiếu" Binding="{Binding SoPhieu}" Width="180"/>
                    <DataGridTextColumn Header="Ngày xuất" Binding="{Binding NgayXuat, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Người nhận" Binding="{Binding NguoiNhan}" Width="180"/>
                    <DataGridTextColumn Header="Kho" Binding="{Binding Kho.TenKho}" Width="130"/>
                    <DataGridTextColumn Header="Bộ phận" Binding="{Binding BoPhan.TenBoPhan}" Width="130"/>
                    <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat=N0}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Edit Form -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Phiếu xuất kho" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding ExportPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,6,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Xuất PDF"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportExcelCommand}" Margin="0,0,10,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background" Value="#1B5E20"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                                    <Setter Property="Height" Value="38"/>
                                    <Setter Property="Padding" Value="16,8"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Xuất Excel"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Lưu phiếu"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Quay lại" Command="{Binding CancelEditCommand}" Style="{StaticResource BtnCancel}"/>
                    </StackPanel>
                </DockPanel>

                <!-- Error -->
                <Border Background="#FFEBEE" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

                <materialDesign:Card Padding="16" Margin="0,0,0,10">
                    <WrapPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Số phiếu" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditSoPhieu}" IsReadOnly="True" Width="180"
                                     Style="{StaticResource FormTextBox}" Background="#F0F0F0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Ngày xuất" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding EditNgayXuat}" Width="150"
                                        Style="{StaticResource FormDatePicker}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Kho xuất *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Khos}" SelectedItem="{Binding EditKho}"
                                      DisplayMemberPath="TenKho" Width="180"
                                      Style="{StaticResource FormComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Người nhận" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditNguoiNhan, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                     Style="{StaticResource FormTextBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Bộ phận" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding BoPhans}" SelectedItem="{Binding EditBoPhan}"
                                      DisplayMemberPath="TenBoPhan" Width="180"
                                      Style="{StaticResource FormComboBox}"
                                      materialDesign:TextFieldAssist.HasClearButton="True"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Mục đích sử dụng" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditMucDichSuDung, UpdateSourceTrigger=PropertyChanged}" Width="200"
                                     Style="{StaticResource FormTextBox}"/>
                        </StackPanel>
                    </WrapPanel>
                </materialDesign:Card>

                <TextBlock Text="Chi tiết vật tư xuất" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <DataGrid ItemsSource="{Binding ChiTietRows}" AutoGenerateColumns="False"
                          CanUserAddRows="False" FontSize="13" RowHeight="40" ColumnHeaderHeight="38"
                          Style="{StaticResource MaterialDesignDataGrid}" Margin="0,0,0,0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Vật tư (chọn từ danh sách)" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.VatTus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding VatTu, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="TenVatTu" IsEditable="True"
                                              BorderThickness="0" Background="Transparent" Padding="4,2"
                                              materialDesign:HintAssist.Hint="-- Chọn vật tư --"
                                              materialDesign:HintAssist.IsFloating="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="ĐVT" Binding="{Binding VatTu.DonViTinh.TenDonVi, Mode=OneWay}" Width="70" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat=N0}" Width="130" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Content="Xóa"
                                            Foreground="#C62828" FontSize="12"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Padding="4,2" Height="28" MinWidth="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Command="{Binding AddRowCommand}" HorizontalAlignment="Stretch" Height="38"
                        BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Cursor="Hand"
                        Margin="0,0,0,8">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" VerticalAlignment="Center" Foreground="#555"/>
                        <TextBlock Text="  Thêm dòng mới" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Background="#FFF3E0" CornerRadius="8" Padding="16,10" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <TextBlock FontSize="16" FontWeight="Bold">
                        <Run Text="TỔNG TIỀN:  "/><Run Text="{Binding TongTien, StringFormat=N0, Mode=OneWay}" Foreground="#C62828"/><Run Text=" đ"/>
                    </TextBlock>
                </Border>

                <materialDesign:Card Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Người ký" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <StackPanel Margin="0,0,12,6">
                                <TextBlock Text="Người lập phiếu" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditNguoiLapPhieu, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,6">
                                <TextBlock Text="Thủ kho" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditThuKho, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,6">
                                <TextBlock Text="Kế toán trưởng" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditKeToanTruong, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,6">
                                <TextBlock Text="Giám đốc" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditGiamDoc, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
