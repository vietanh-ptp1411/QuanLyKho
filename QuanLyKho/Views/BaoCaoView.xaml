<UserControl x:Class="QuanLyKho.Views.BaoCaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <TextBlock Text="Xuất hóa đơn / Báo cáo" Style="{StaticResource PageTitle}" DockPanel.Dock="Top"/>

        <TabControl SelectedIndex="{Binding SelectedTab}"
                    Style="{StaticResource MaterialDesignFilledTabControl}">

            <!-- TAB 1: Tồn kho theo tháng -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Nhập xuất tồn kho"/>
                    </StackPanel>
                </TabItem.Header>
                <StackPanel Margin="16" MaxWidth="600" HorizontalAlignment="Left">
                    <TextBlock Text="Chọn tháng và kho để xuất báo cáo nhập xuất tồn" FontSize="13" Foreground="Gray" Margin="0,0,0,12"/>
                    <WrapPanel Margin="0,0,0,12">
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Tháng" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"
                                      Width="100" Style="{StaticResource FormComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Năm" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"
                                      Width="120" Style="{StaticResource FormComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Kho" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Khos}" SelectedItem="{Binding SelectedKho}"
                                      DisplayMemberPath="TenKho" Width="220" Style="{StaticResource FormComboBox}"/>
                        </StackPanel>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Command="{Binding ExportTonKhoPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Xuất PDF"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportTonKhoExcelCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background" Value="#1B5E20"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                                    <Setter Property="Height" Value="38"/>
                                    <Setter Property="Padding" Value="16,8"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Xuất Excel"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32" FontWeight="SemiBold" FontSize="12"/>
                </StackPanel>
            </TabItem>

            <!-- TAB 2: Phiếu nhập kho -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PackageDown" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Phiếu nhập kho"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel Margin="16">
                    <TextBlock Text="Tích chọn phiếu nhập kho cần xuất (có thể chọn nhiều)" FontSize="13" Foreground="Gray"
                               DockPanel.Dock="Top" Margin="0,0,0,8"/>

                    <!-- Nút xuất ở dưới -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ExportPhieuNhapPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Xuất PDF"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportPhieuNhapExcelCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background" Value="#1B5E20"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                                        <Setter Property="Height" Value="38"/>
                                        <Setter Property="Padding" Value="16,8"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Xuất Excel"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32" FontWeight="SemiBold" FontSize="12" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Bảng danh sách -->
                    <DataGrid ItemsSource="{Binding PhieuNhaps}"
                              AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                              FontSize="13" RowHeight="40" ColumnHeaderHeight="38"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Chọn" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Số phiếu" Binding="{Binding Phieu.SoPhieu}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Ngày nhập" Binding="{Binding Phieu.NgayNhap, StringFormat=dd/MM/yyyy}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Người giao hàng" Binding="{Binding Phieu.NguoiGiaoHang}" Width="3*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Kho" Binding="{Binding Phieu.Kho.TenKho}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding Phieu.TongTien, StringFormat=N0}" Width="2*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- TAB 3: Phiếu xuất kho -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PackageUp" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Phiếu xuất kho"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel Margin="16">
                    <TextBlock Text="Tích chọn phiếu xuất kho cần xuất (có thể chọn nhiều)" FontSize="13" Foreground="Gray"
                               DockPanel.Dock="Top" Margin="0,0,0,8"/>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ExportPhieuXuatPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Xuất PDF"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportPhieuXuatExcelCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background" Value="#1B5E20"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                                        <Setter Property="Height" Value="38"/>
                                        <Setter Property="Padding" Value="16,8"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Xuất Excel"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32" FontWeight="SemiBold" FontSize="12" Margin="0,6,0,0"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding PhieuXuats}"
                              AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                              FontSize="13" RowHeight="40" ColumnHeaderHeight="38"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Chọn" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Số phiếu" Binding="{Binding Phieu.SoPhieu}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Ngày xuất" Binding="{Binding Phieu.NgayXuat, StringFormat=dd/MM/yyyy}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Người nhận" Binding="{Binding Phieu.NguoiNhan}" Width="3*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Kho" Binding="{Binding Phieu.Kho.TenKho}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding Phieu.TongTien, StringFormat=N0}" Width="2*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- TAB 4: Đề nghị cấp VT -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Đề nghị cấp VT"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel Margin="16">
                    <TextBlock Text="Tích chọn phiếu đề nghị cần xuất (có thể chọn nhiều)" FontSize="13" Foreground="Gray"
                               DockPanel.Dock="Top" Margin="0,0,0,8"/>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ExportDeNghiPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Xuất PDF"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportDeNghiExcelCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background" Value="#1B5E20"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                                        <Setter Property="Height" Value="38"/>
                                        <Setter Property="Padding" Value="16,8"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Xuất Excel"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32" FontWeight="SemiBold" FontSize="12" Margin="0,6,0,0"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding DeNghis}"
                              AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                              FontSize="13" RowHeight="40" ColumnHeaderHeight="38"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Chọn" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Số phiếu" Binding="{Binding Phieu.SoPhieu}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding Phieu.NgayDeNghi, StringFormat=dd/MM/yyyy}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Người đề nghị" Binding="{Binding Phieu.NguoiDeNghi}" Width="3*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Bộ phận" Binding="{Binding Phieu.BoPhan.TenBoPhan}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding Phieu.TrangThai, Converter={StaticResource TrangThaiFormat}}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
