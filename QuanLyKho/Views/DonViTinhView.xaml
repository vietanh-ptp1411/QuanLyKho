<UserControl x:Class="QuanLyKho.Views.DonViTinhView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề màu đỏ căn giữa -->
        <TextBlock Text="QUẢN LÝ ĐƠN VỊ TÍNH" Style="{StaticResource PageTitleRed}"/>

        <!-- Nút thêm mới bên trái -->
        <Button Grid.Row="1" Command="{Binding AddCommand}" Style="{StaticResource BtnAddGreen}"
                HorizontalAlignment="Left" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Thêm đơn vị tính"/>
            </StackPanel>
        </Button>

        <!-- Form chỉnh sửa -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,15"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Tên đơn vị tính" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditTenDonVi, UpdateSourceTrigger=PropertyChanged}"
                             Width="300" HorizontalAlignment="Left"
                             Style="{StaticResource FormTextBox}"
                             materialDesign:HintAssist.Hint="VD: Cái, Kg, m..."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Lưu"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Hủy" Command="{Binding CancelCommand}" Style="{StaticResource BtnCancel}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- DataGrid giữ nguyên -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                  Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Tên đơn vị tính" Binding="{Binding TenDonVi}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
