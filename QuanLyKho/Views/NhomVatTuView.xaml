<UserControl x:Class="QuanLyKho.Views.NhomVatTuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề màu đỏ căn giữa -->
        <TextBlock Text="QUẢN LÝ NHÓM VẬT TƯ" Style="{StaticResource PageTitleRed}"/>

        <!-- Nút thêm mới bên trái -->
        <Button Grid.Row="1" Command="{Binding AddCommand}" Style="{StaticResource BtnAddGreen}"
                HorizontalAlignment="Left" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Thêm nhóm vật tư"/>
            </StackPanel>
        </Button>

        <!-- Form chỉnh sửa -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,15"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <WrapPanel>
                    <StackPanel Margin="0,0,15,8">
                        <TextBlock Text="Mã nhóm" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditMaNhom, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Style="{StaticResource FormTextBox}"
                                 materialDesign:HintAssist.Hint="VD: VPP"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,8">
                        <TextBlock Text="Tên nhóm" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditTenNhom, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300" Style="{StaticResource FormTextBox}"
                                 materialDesign:HintAssist.Hint="VD: Văn phòng phẩm"/>
                    </StackPanel>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Lưu"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Hủy" Command="{Binding CancelCommand}" Style="{StaticResource BtnCancel}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- DataGrid giữ nguyên -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                                    Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Width="55"
                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                    Converter={StaticResource IndexConverter}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Mã nhóm" Binding="{Binding MaNhom}" Width="180"/>
                <DataGridTextColumn Header="Tên nhóm" Binding="{Binding TenNhom}" Width="*"/>
                <DataGridTemplateColumn Header="Thao tác" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource BtnGridEdit}" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Sửa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource BtnGridDelete}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Xóa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Phân trang -->
        <Border Grid.Row="4" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1"
                CornerRadius="0,0,8,8" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Foreground="#64748B">
                    <Run Text="Hiển thị "/>
                    <Run Text="{Binding DanhSach.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text=" mục"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding FirstPageCommand}" Content="⟨⟨" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    <Button Command="{Binding PrevPageCommand}" Content="⟨" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,8,0"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0">
                        <Run Text="Trang "/>
                        <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <Button Command="{Binding NextPageCommand}" Content="⟩" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    <Button Command="{Binding LastPageCommand}" Content="⟩⟩" Padding="8,4" MinWidth="36" Height="32"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12"
                            materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
