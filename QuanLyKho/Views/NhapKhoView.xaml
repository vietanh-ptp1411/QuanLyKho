<UserControl x:Class="QuanLyKho.Views.NhapKhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:QuanLyKho.Helpers">
    <Grid>
        <!-- List View -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="NHẬP KHO" Style="{StaticResource PageTitleRed}"/>

            <!-- Filters -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                         Width="220" materialDesign:HintAssist.Hint="Tìm số phiếu, người giao..."
                         Style="{StaticResource FilterTextBox}"
                         Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FilterFromDate}" Width="145" Margin="0,0,6,0"
                            materialDesign:HintAssist.Hint="Từ ngày" Style="{StaticResource FilterDatePicker}"/>
                <DatePicker SelectedDate="{Binding FilterToDate}" Width="145" Margin="0,0,6,0"
                            materialDesign:HintAssist.Hint="Đến ngày" Style="{StaticResource FilterDatePicker}"/>
                <Button Command="{Binding FilterCommand}" Style="{StaticResource BtnSecondary}" Height="38">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Filter" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Lọc"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!-- Nút hành động -->
            <WrapPanel Grid.Row="2" Margin="0,0,0,12">
                <Button Command="{Binding AddNewCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Tạo phiếu nhập"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding PrintCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Printer" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="In"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xuất PDF"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportExcelCommand}" Style="{StaticResource BtnExcel}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xuất Excel"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSach}" SelectedItem="{Binding SelectedPhieu}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      FontSize="13" RowHeight="36" ColumnHeaderHeight="38"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT" Width="55"
                                        Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                        Converter={StaticResource IndexConverter}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Số phiếu" Binding="{Binding SoPhieu}" Width="180"/>
                    <DataGridTextColumn Header="Ngày nhập" Binding="{Binding NgayNhap, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Người giao hàng" Binding="{Binding NguoiGiaoHang}" Width="*"/>
                    <DataGridTextColumn Header="Kho" Binding="{Binding Kho.TenKho}" Width="150"/>
                    <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat=N0}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Thao tác" Width="165">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel VerticalAlignment="Center" LastChildFill="False" Margin="8,0">
                                    <Button DockPanel.Dock="Left" Command="{Binding DataContext.EditPhieuItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource BtnGridEdit}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sửa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button DockPanel.Dock="Right" Command="{Binding DataContext.DeletePhieuItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource BtnGridDelete}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Xóa" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Phân trang -->
            <Border Grid.Row="4" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1"
                    CornerRadius="0,0,8,8" Padding="12,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Foreground="#64748B">
                        <Run Text="Hiển thị "/>
                        <Run Text="{Binding DanhSach.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" mục"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding FirstPageCommand}" Content="⟨⟨" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <Button Command="{Binding PrevPageCommand}" Content="⟨" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0">
                            <Run Text="Trang "/>
                            <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                        <Button Command="{Binding NextPageCommand}" Content="⟩" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                        <Button Command="{Binding LastPageCommand}" Content="⟩⟩" Padding="8,4" MinWidth="36" Height="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="12"
                                materialDesign:ButtonAssist.CornerRadius="6" BorderBrush="#CBD5E1"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Edit Form -->
        <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Phiếu nhập kho" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding PrintCommand}" Style="{StaticResource BtnSecondary}" Margin="0,0,6,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Printer" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="In"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportPdfCommand}" Style="{StaticResource BtnPrimary}" Margin="0,0,6,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Xuất PDF"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportExcelCommand}" Margin="0,0,10,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Height" Value="38"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Xuất Excel"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource BtnSave}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Lưu phiếu"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Quay lại" Command="{Binding CancelEditCommand}" Style="{StaticResource BtnCancel}"/>
                    </StackPanel>
                </DockPanel>

                <materialDesign:Card Padding="16" Margin="0,0,0,10">
                    <WrapPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Số phiếu" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditSoPhieu}" IsReadOnly="True" Width="180"
                                     Style="{StaticResource FormTextBox}" Background="#F0F0F0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Ngày nhập" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding EditNgayNhap}" Width="150"
                                        Style="{StaticResource FormDatePicker}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Kho nhập *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Khos}" SelectedItem="{Binding EditKho}"
                                      DisplayMemberPath="TenKho" Width="200"
                                      Style="{StaticResource FormComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Người giao hàng" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditNguoiGiaoHang, UpdateSourceTrigger=PropertyChanged}" Width="200"
                                     Style="{StaticResource FormTextBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Ghi chú" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditGhiChu, UpdateSourceTrigger=PropertyChanged}" Width="250"
                                     Style="{StaticResource FormTextBox}"/>
                        </StackPanel>
                    </WrapPanel>
                </materialDesign:Card>

                <!-- Chi tiết -->
                <TextBlock Text="Chi tiết vật tư nhập" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <DataGrid ItemsSource="{Binding ChiTietRows}" AutoGenerateColumns="False"
                          CanUserAddRows="False" FontSize="13" RowHeight="40" ColumnHeaderHeight="38"
                          Style="{StaticResource MaterialDesignDataGrid}" Margin="0,0,0,0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Vật tư (chọn từ danh sách)" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.VatTus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding VatTu, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="TenVatTu" IsEditable="True"
                                              helpers:AutoCompleteBehavior.IsEnabled="True"
                                              BorderThickness="0" Background="Transparent" Padding="4,2"
                                              materialDesign:HintAssist.Hint="-- Gõ để tìm vật tư --"
                                              materialDesign:HintAssist.IsFloating="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="ĐVT" Binding="{Binding VatTu.DonViTinh.TenDonVi, Mode=OneWay}" Width="70" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat=N0}" Width="130" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Content="Xóa"
                                            Foreground="#DC2626" FontSize="12"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Padding="4,2" Height="28" MinWidth="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Nút thêm dòng ở cuối bảng -->
                <Button Command="{Binding AddRowCommand}" HorizontalAlignment="Stretch" Height="38"
                        BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Cursor="Hand"
                        Margin="0,0,0,8">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" VerticalAlignment="Center" Foreground="#555"/>
                        <TextBlock Text="  Thêm dòng mới" Foreground="#555" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Tổng tiền -->
                <Border Background="#EFF6FF" CornerRadius="8" Padding="16,10" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <TextBlock FontSize="16" FontWeight="Bold">
                        <Run Text="TỔNG TIỀN:  "/><Run Text="{Binding TongTien, StringFormat=N0, Mode=OneWay}" Foreground="#DC2626"/><Run Text=" đ"/>
                    </TextBlock>
                </Border>

                <!-- Chữ ký -->
                <materialDesign:Card Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Người ký" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <StackPanel Margin="0,0,12,6">
                                <TextBlock Text="Người lập phiếu" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditNguoiLapPhieu, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,6">
                                <TextBlock Text="Thủ kho" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditThuKho, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,6">
                                <TextBlock Text="Kế toán trưởng" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditKeToanTruong, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,6">
                                <TextBlock Text="Giám đốc" Margin="0,0,0,4" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding EditGiamDoc, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
