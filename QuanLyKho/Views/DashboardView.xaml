<UserControl x:Class="QuanLyKho.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:System="clr-namespace:System;assembly=mscorlib">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="0,0,0,24">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Tổng quan" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <Binding Source="{x:Static System:DateTime.Now}" StringFormat="{}Cập nhật: {0:dd/MM/yyyy HH:mm}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </DockPanel>

            <!-- KPI Row 1: 3 stat cards -->
            <UniformGrid Columns="3" Margin="0,0,0,16">

                <!-- Tong so vat tu -->
                <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#000"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="{StaticResource PrimaryLight}" DockPanel.Dock="Left">
                            <materialDesign:PackIcon Kind="CubeOutline" Width="24" Height="24" Foreground="{StaticResource Primary}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Tổng số vật tư" Style="{StaticResource StatLabel}"/>
                            <TextBlock Text="{Binding TongSoVatTu}" Style="{StaticResource StatValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- So kho -->
                <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#000"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="{StaticResource WarningLight}" DockPanel.Dock="Left">
                            <materialDesign:PackIcon Kind="Warehouse" Width="24" Height="24" Foreground="{StaticResource Warning}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Số kho" Style="{StaticResource StatLabel}"/>
                            <TextBlock Text="{Binding TongSoKho}" Style="{StaticResource StatValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Thang hien tai -->
                <Border Background="White" CornerRadius="12" Padding="24,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#000"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="{StaticResource InfoLight}" DockPanel.Dock="Left">
                            <materialDesign:PackIcon Kind="CalendarMonth" Width="24" Height="24" Foreground="{StaticResource Info}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Tháng hiện tại" Style="{StaticResource StatLabel}"/>
                            <TextBlock Text="{Binding Source={x:Static System:DateTime.Now}, StringFormat='{}{0:MM/yyyy}'}"
                                       Style="{StaticResource StatValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <!-- KPI Row 2: Nhap / Xuat thang -->
            <UniformGrid Columns="2" Margin="0,0,0,16">

                <!-- Nhap kho thang nay -->
                <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#000"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="{StaticResource SuccessLight}" DockPanel.Dock="Left">
                            <materialDesign:PackIcon Kind="PackageDown" Width="24" Height="24" Foreground="{StaticResource Success}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Nhập kho tháng này" Style="{StaticResource StatLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding SoPhieuNhapThang}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Success}"/>
                                <TextBlock Text=" phiếu" FontSize="14" Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Bottom" Margin="0,0,16,3"/>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,4">
                                    <TextBlock.Text>
                                        <Binding Path="TongGiaTriNhapThang" StringFormat="{}{0:N0} đ"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Xuat kho thang nay -->
                <Border Background="White" CornerRadius="12" Padding="24,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#000"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="{StaticResource DangerLight}" DockPanel.Dock="Left">
                            <materialDesign:PackIcon Kind="PackageUp" Width="24" Height="24" Foreground="{StaticResource Danger}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Xuất kho tháng này" Style="{StaticResource StatLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding SoPhieuXuatThang}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Danger}"/>
                                <TextBlock Text=" phiếu" FontSize="14" Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Bottom" Margin="0,0,16,3"/>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,4">
                                    <TextBlock.Text>
                                        <Binding Path="TongGiaTriXuatThang" StringFormat="{}{0:N0} đ"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
